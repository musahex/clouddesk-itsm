# CloudDesk API — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.

# Server port (default: 5001)
PORT=5001

# MongoDB connection string (required)
# Local:      mongodb://localhost:27017/clouddesk
# Atlas:      mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/clouddesk?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/clouddesk

# JWT signing secret (required)
# Development: any string works
# Production:  must be at least 32 characters — generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_strong_secret_at_least_32_chars_for_production

# Environment (default: development)
# Use 'production' in deployed environments — disables dev admin auto-creation
NODE_ENV=development

# Frontend URL for CORS (default in dev: http://localhost:5173)
# Required in production — set to your deployed frontend URL
# Example: https://clouddesk.example.com
# CLIENT_URL=
