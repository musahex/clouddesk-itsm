# CloudDesk Web Client — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.

# Sentry frontend error tracking (all optional — disabled by default)
# Set VITE_SENTRY_ENABLED=true and VITE_SENTRY_DSN to enable.
# Never commit a real DSN to the repository.
VITE_SENTRY_ENABLED=false
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_RELEASE=clouddesk-web@local
